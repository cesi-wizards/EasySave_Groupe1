# Indique qu'il s'agit du fichier de configuration racine
root = true

# Règles générales pour tous les fichiers
[*]
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = crlf

# Fichiers JSON, XML, et Markdown
[*.{json,xml,md,yml,yaml}]
indent_size = 2

# Règles spécifiques pour les fichiers C#
[*.cs]
# ==========================================
# Règles globales .NET
# ==========================================

# Organiser les "using" (System en premier)
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# ==========================================
# Style de code C# (C# 10+)
# ==========================================

# Utiliser les namespaces avec portée de fichier (File-scoped namespaces)
csharp_style_namespace_declarations = file_scoped:warning

# Utilisation de 'var'
# Préférer le type explicite pour les types natifs (int, string, etc.)
csharp_style_var_for_built_in_types = false:suggestion
# Utiliser 'var' quand le type est évident (ex: var obj = new Object();)
csharp_style_var_when_type_is_apparent = true:suggestion
# Préférer le type explicite le reste du temps
csharp_style_var_elsewhere = false:suggestion

# Membres sous forme d'expression (=>)
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_operators = false:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_indexers = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion

# ==========================================
# Formatage (Style Allman)
# ==========================================

# Les accolades doivent toujours être sur une nouvelle ligne
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# Indentation
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = flush_left

# ==========================================
# Conventions de nommage
# ==========================================

# 1. Les classes, structs, enums, etc. doivent être en PascalCase
dotnet_naming_rule.pascal_case_for_types.severity = warning
dotnet_naming_rule.pascal_case_for_types.symbols = types
dotnet_naming_rule.pascal_case_for_types.style = pascal_case

dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum, delegate
dotnet_naming_symbols.types.applicable_accessibilities = *

dotnet_naming_style.pascal_case.capitalization = pascal_case

# 2. Les interfaces doivent commencer par un 'I'
dotnet_naming_rule.interface_should_be_begins_with_i.severity = warning
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interfaces
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = *

dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

# 3. Les champs privés doivent commencer par un '_' et être en camelCase
dotnet_naming_rule.private_fields_with_underscore.severity = warning
dotnet_naming_rule.private_fields_with_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_with_underscore.style = prefix_underscore

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.prefix_underscore.required_prefix = _
dotnet_naming_style.prefix_underscore.capitalization = camel_case