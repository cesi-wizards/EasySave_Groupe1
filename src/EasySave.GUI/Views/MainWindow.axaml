<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EasySave.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:EasySave.GUI.Views"
        mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="540"
        x:Class="EasySave.GUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/EasySave-logo.ico"
        Title="EasySave"
        MinWidth="700"
        MinHeight="460"
        Background="White">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="210,*">

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- SIDEBAR                                                            -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource SidebarBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- New Backup CTA (bottom) -->
                <Border DockPanel.Dock="Bottom" Padding="10,8,10,16">
                    <Button Classes="cta"
                            Click="OnNewBackupClick">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <TextBlock Text="{Binding Localization[NewBackup]}"
                                       VerticalAlignment="Center"
                                       />
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="14,20,14,10">
                    <StackPanel Orientation="Horizontal" Spacing="9">
                        <Border Width="30" Height="30" CornerRadius="8"
                                Background="#3B6AF7">
                            <Image Source="/Assets/EasySave-logo.png"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="EasySave"
                                   FontWeight="Bold" FontSize="15"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"
                                   LetterSpacing="-0.3"/>
                    </StackPanel>
                </Border>

                <!-- Stats pills -->
                <Border DockPanel.Dock="Top" Padding="10,0,10,14">
                    <Grid ColumnDefinitions="*,5,*,5,*">

                        <!-- Total -->
                        <Border Grid.Column="0" CornerRadius="8"
                                Background="#143B6AF7" Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalJobs}"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="#3B6AF7"/>
                                <TextBlock Text="TOTAL"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}"
                                           LetterSpacing="1"/>
                            </StackPanel>
                        </Border>

                        <!-- Done -->
                        <Border Grid.Column="2" CornerRadius="8"
                                Background="#1422C55E" Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="{Binding DoneJobs}"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="#16A34A"/>
                                <TextBlock Text="{Binding Localization[DoneLabel]}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}"
                                           LetterSpacing="1"/>
                            </StackPanel>
                        </Border>

                        <!-- Active -->
                        <Border Grid.Column="4" CornerRadius="8"
                                Background="#0F000000" Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="{Binding RunningJobs}"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="{Binding Localization[ActiveLabel]}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}"
                                           LetterSpacing="1"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="8,0">
                    <Button Classes="nav" Click="OnJobsNavClick">
                        <StackPanel Orientation="Horizontal" Spacing="9">
                            <TextBlock Text="{Binding Localization[BackupJobsNav]}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="nav" Click="OnLogsNavClick">
                        <StackPanel Orientation="Horizontal" Spacing="9">
                            <TextBlock Text="{Binding Localization[LogsNav]}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="nav" Click="OnSettingsNavClick">
                        <StackPanel Orientation="Horizontal" Spacing="9">
                            <TextBlock Text="{Binding Localization[SettingsButton]}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Spacer -->
                <Border/>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                                       -->
        <!-- ══════════════════════════════════════════════════════════════════ -->


        <Grid Grid.Column="1" RowDefinitions="Auto,*" Background="White">

            <!-- Toolbar -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
                  Margin="20,16,20,0">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding CurrentPageTitle}"
                               FontWeight="Bold" FontSize="18"
                               Foreground="{StaticResource TextPrimary}"
                               LetterSpacing="-0.4"/>
                    <TextBlock FontSize="12"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,2,0,0"
                               IsVisible="{Binding ShowJobsPage}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} job(s)">
                                <Binding Path="TotalJobs"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <!-- Language toggle -->
                    <Button Classes="icon"
                            Content="{Binding Localization.LanguageButton}"
                            Command="{Binding Localization.ToggleLanguageCommand}"
                            FontWeight="SemiBold" FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- Page area -->
            <Panel Grid.Row="1" Margin="0,12,0,0">
                <Panel IsVisible="{Binding ShowJobsPage}">
                    <views:JobsPage DataContext="{Binding JobsPageVm}"/>
                </Panel>
                <Panel IsVisible="{Binding ShowLogsPage}">
                    <views:LogsPage DataContext="{Binding LogsPageVm}"/>
                </Panel>
                <Panel IsVisible="{Binding ShowSettingsPage}">
                    <views:SettingsPage DataContext="{Binding SettingsPageVm}"/>
                </Panel>
            </Panel>
        </Grid>
    </Grid>
</Window>
