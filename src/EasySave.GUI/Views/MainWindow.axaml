<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EasySave.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="EasySave.GUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/EasySave-logo.ico"
        Title="EasySave">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" Margin="20">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,8,Auto">
            <Button Grid.Column="0"
                    Content="{Binding Localization.NewBackup}"
                    Click="OnNewBackupClick"/>
            <Button Grid.Column="2"
                    Content="{Binding Localization.LanguageButton}"
                    Command="{Binding Localization.ToggleLanguageCommand}"/>
            <Button Grid.Column="4"
                    Content="{Binding Localization.SettingsButton}"
                    Click="OnSettingsClick"/>
        </Grid>

        <ListBox Grid.Row="1"
                 Margin="0,12,0,0"
                 ItemsSource="{Binding BackupJobs}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:BackupJobViewModel">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="4">

                        <StackPanel Grid.Column="0" Spacing="4">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Config.Name}" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Config.Type}" Margin="12,0,12,0" VerticalAlignment="Center" Foreground="Gray"/>
                                <TextBlock Grid.Column="2" Text="{Binding Config.LogFileType}" VerticalAlignment="Center" Foreground="Gray"/>
                            </Grid>
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" Height="6"/>
                            <TextBlock Text="{Binding CurrentFile}" FontSize="11" Foreground="Gray"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="{Binding PauseButtonText}"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RunOrPauseJobCommand}"
                                CommandParameter="{Binding}"/>
                        
                        <Button Grid.Column="2"
                                Content="✕"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveJobCommand}"
                                CommandParameter="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>

</Window>
