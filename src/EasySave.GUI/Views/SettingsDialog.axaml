<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EasySave.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="380" d:DesignHeight="180"
        x:Class="EasySave.GUI.Views.SettingsDialog"
        x:DataType="vm:SettingsDialogViewModel"
        Title="{Binding Localization.SettingsTitle}"
        Width="380"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:SettingsDialogViewModel>
            <x:Arguments>
                <x:String></x:String>
            </x:Arguments>
        </vm:SettingsDialogViewModel>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto" Margin="20">

        <StackPanel Grid.Row="0" Spacing="12">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Localization.LogFileTypeLabel}"/>
                <ComboBox ItemsSource="{Binding LogFileTypes}"
                          SelectedItem="{Binding SelectedLogFileType}"
                          HorizontalAlignment="Stretch"/>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Localization.BlockingApplicationLabel}"/>
                <TextBlock Text="{Binding Localization.BlockingApplicationDescription}"
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                <TextBox Text="{Binding BlockingApp}"
                         PlaceholderText="{Binding Localization.BlockingAppPlaceholder}"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*,8,*" Margin="0,16,0,0">
            <Button Grid.Column="0" Content="{Binding Localization.CancelButton}"
                    Command="{Binding CancelCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="{Binding Localization.SaveButton}"
                    Command="{Binding ConfirmCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Classes="accent"/>
        </Grid>

    </Grid>

</Window>
